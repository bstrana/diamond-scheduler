{
  "realm": "diamond",
  "displayName": "Diamond Scheduler",
  "displayNameHtml": "<strong>Diamond Scheduler</strong>",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "roles": {
    "realm": [
      {
        "name": "system_admin",
        "description": "Platform superadmin — inherits tenant_admin",
        "composite": true,
        "composites": { "realm": ["tenant_admin"] },
        "clientRole": false,
        "attributes": {}
      },
      {
        "name": "tenant_admin",
        "description": "Manages a single tenant — inherits scheduler_admin",
        "composite": true,
        "composites": { "realm": ["scheduler_admin"] },
        "clientRole": false,
        "attributes": {}
      },
      {
        "name": "scheduler_admin",
        "description": "Publish/delete schedules, manage score links — inherits scheduler_editor",
        "composite": true,
        "composites": { "realm": ["scheduler_editor"] },
        "clientRole": false,
        "attributes": {}
      },
      {
        "name": "scheduler_editor",
        "description": "Edit games and enter scores — inherits scheduler_viewer",
        "composite": true,
        "composites": { "realm": ["scheduler_viewer"] },
        "clientRole": false,
        "attributes": {}
      },
      {
        "name": "scheduler_viewer",
        "description": "Read-only access to the calendar",
        "composite": false,
        "clientRole": false,
        "attributes": {}
      }
    ]
  },

  "groups": [
    {
      "name": "system",
      "realmRoles": ["system_admin"],
      "subGroups": [
        {
          "name": "admins",
          "realmRoles": ["system_admin"],
          "subGroups": []
        }
      ]
    },
    {
      "name": "tenants",
      "realmRoles": [],
      "subGroups": [
        {
          "name": "acme",
          "realmRoles": [],
          "attributes": { "org_id": ["acme-org-id-replace-me"] },
          "subGroups": [
            {
              "name": "admins",
              "realmRoles": ["tenant_admin"],
              "subGroups": []
            },
            {
              "name": "editors",
              "realmRoles": ["scheduler_editor"],
              "subGroups": []
            },
            {
              "name": "viewers",
              "realmRoles": ["scheduler_viewer"],
              "subGroups": []
            }
          ]
        }
      ]
    }
  ],

  "clientScopes": [
    {
      "name": "scheduler",
      "description": "Diamond Scheduler claims: org_id + realm roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "org_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "org_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "org_id",
            "jsonType.label": "String",
            "multivalued": "false",
            "aggregate.attrs": "false"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    }
  ],

  "clients": [
    {
      "clientId": "diamond-scheduler",
      "name": "Diamond Scheduler (SPA)",
      "description": "Public SPA client — PKCE S256. Replace redirect URIs with your domain.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://your-app.example.com/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "https://your-app.example.com",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://your-app.example.com/*",
        "backchannel.logout.session.required": "true"
      },
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email", "scheduler"],
      "optionalClientScopes": ["offline_access"]
    },
    {
      "clientId": "diamond-scheduler-server",
      "name": "Diamond Scheduler (Server)",
      "description": "Confidential back-channel client for ICS token introspection. Copy the generated secret to KC_CLIENT_SECRET.",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": []
    },
    {
      "clientId": "diamond-scheduler-embed",
      "name": "Diamond Scheduler (Embed widget)",
      "description": "Public client for the embeddable schedule widget — check-sso, no forced redirect.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "https://your-app.example.com/silent-check-sso.html",
        "http://localhost:5173/silent-check-sso.html"
      ],
      "webOrigins": ["+"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email", "scheduler"],
      "optionalClientScopes": []
    }
  ],

  "users": [
    {
      "username": "platform-admin",
      "enabled": false,
      "emailVerified": true,
      "firstName": "Platform",
      "lastName": "Admin",
      "email": "platform-admin@example.com",
      "realmRoles": ["system_admin"],
      "groups": ["/system/admins"],
      "attributes": {},
      "requiredActions": ["UPDATE_PASSWORD"]
    },
    {
      "username": "acme-admin",
      "enabled": false,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "Acme",
      "email": "admin@acme.example.com",
      "groups": ["/tenants/acme/admins"],
      "attributes": { "org_id": ["acme-org-id-replace-me"] },
      "requiredActions": ["UPDATE_PASSWORD"]
    },
    {
      "username": "acme-viewer",
      "enabled": false,
      "emailVerified": true,
      "firstName": "Viewer",
      "lastName": "Acme",
      "email": "viewer@acme.example.com",
      "groups": ["/tenants/acme/viewers"],
      "attributes": { "org_id": ["acme-org-id-replace-me"] },
      "requiredActions": ["UPDATE_PASSWORD"]
    }
  ]
}
